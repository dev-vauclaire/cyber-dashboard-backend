DB_HOST=localhost
DB_PORT=5432
DB_NAME=cyber_dashboard
DB_USER=postgres
DB_PASSWORD=postgres

LIMIT_REQUEST_PER_DAY=24
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=10
POLL_SAFETY_WINDOW_SECONDS=300
CYBER_DASHBOARD_SECRET_KEY_FILE=/run/secrets/cyber_dashboard_secret_key
CYBER_DASHBOARD_SECRET_KEY=

OGO_BASE_URL=https://ogo.example.com

SERENICITY_BASE_URL=https://api.example.com/serenicity
